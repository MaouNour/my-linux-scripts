#!/usr/bin/env python3
import sqlite3
import random
import subprocess
import threading
import queue
import sys
import time
import shutil
import json
from pathlib import Path
from urllib.parse import unquote, urlparse
from pydbus import SessionBus
from gi.repository import GLib
import os

# --- Paths and extensions ---
DB_PATH = Path.home() / ".local/share/music_index.db"
AUDIO_EXTS = {".mp3", ".m4a", ".flac", ".ogg", ".wav", ".opus"}
VIDEO_EXTS = {".mp4", ".mkv", ".webm", ".avi", ".mov", ".flv"}
SUPPORTED_EXTS = AUDIO_EXTS | VIDEO_EXTS

# --- Loudness normalization (EBU R128 via ffmpeg's loudnorm filter) ---
LOUDNESS_TARGET_LUFS = -16.0   # typical target for personal music playback
LOUDNESS_MAX_BOOST_DB = 12.0   # never boost a quiet/silent file more than this
LOUDNESS_MAX_CUT_DB = 15.0     # never cut an already-loud file more than this

# --- Globals ---
playlist = []
playlist_ids = []  # Track database IDs for currently playing playlist
index = 0
paused = False
proc = None
cmd_queue = queue.Queue()
mpris_player = None
bus = None

# playback position / capability tracking for MPRIS
_play_started_at = 0.0     # time.time() when current song (re)started
_position_at_start = 0.0   # seconds already elapsed at that moment
_pause_started_at = None
_current_volume = 1.0      # 0.0 - 1.0
_current_length = 0.0      # seconds, from ffprobe (0 if unknown)
_loop_status = "None"      # "None" | "Track" | "Playlist"
_shuffle = False           # playlist is shuffled once at load; sequential thereafter unless toggled on

# Guards every playback-state transition (play/stop/pause/resume/next/prev/
# seek/advance) so the manual-command thread(s) and the monitor thread can
# never both spawn/replace the ffplay process at the same time.
_lock = threading.RLock()


# --- Database helpers ---
def get_connection():
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA foreign_keys = ON")
    return conn


def get_playlist_tracks(playlist_name):
    conn = get_connection()
    c = conn.cursor()
    c.execute("SELECT id FROM playlists WHERE name = ?", (playlist_name,))
    row = c.fetchone()
    if not row:
        print(f"❌ Playlist '{playlist_name}' does not exist.")
        conn.close()
        return [], []
    playlist_id = row[0]
    c.execute(
        """
        SELECT t.id, t.path
        FROM tracks t
        JOIN playlist_tracks pt ON t.id = pt.track_id
        WHERE pt.playlist_id = ?
        ORDER BY t.filename ASC
    """,
        (playlist_id,),
    )
    rows = c.fetchall()
    conn.close()
    if not rows:
        print(f"⚠️ Playlist '{playlist_name}' is empty.")
    ids = [r[0] for r in rows]
    paths = [r[1] for r in rows]
    return paths, ids


def add_current_to_playlist(current_id, playlist_name):
    conn = get_connection()
    c = conn.cursor()
    c.execute("INSERT OR IGNORE INTO playlists (name) VALUES (?)", (playlist_name,))
    c.execute("SELECT id FROM playlists WHERE name = ?", (playlist_name,))
    playlist_id = c.fetchone()[0]
    try:
        c.execute(
            "INSERT OR IGNORE INTO playlist_tracks (playlist_id, track_id) VALUES (?, ?)",
            (playlist_id, current_id),
        )
        print(f"✅ Added track {current_id} to playlist '{playlist_name}'")
    except Exception as e:
        print(f"⚠️ Could not add track: {e}")
    conn.commit()
    conn.close()


def remove_current_from_playlist(current_id, playlist_name):
    conn = get_connection()
    c = conn.cursor()
    c.execute("SELECT id FROM playlists WHERE name = ?", (playlist_name,))
    row = c.fetchone()
    if not row:
        print(f"❌ Playlist '{playlist_name}' does not exist.")
        conn.close()
        return
    playlist_id = row[0]
    c.execute(
        "DELETE FROM playlist_tracks WHERE playlist_id = ? AND track_id = ?",
        (playlist_id, current_id),
    )
    conn.commit()
    conn.close()
    print(f"✅ Removed track {current_id} from playlist '{playlist_name}'")


# --- Folder scanning ---
def scan_folder(folder):
    folder = Path(folder).expanduser().resolve()
    songs = []
    for root, _, files in os.walk(folder):
        for f in files:
            if Path(f).suffix.lower() in SUPPORTED_EXTS:
                songs.append(str(Path(root) / f))
    return songs


def get_track_length(path):
    """Best-effort track duration in seconds via ffprobe. Returns 0.0 if unavailable."""
    if not shutil.which("ffprobe"):
        return 0.0
    try:
        out = subprocess.run(
            [
                "ffprobe", "-v", "error",
                "-show_entries", "format=duration",
                "-of", "default=noprint_wrappers=1:nokey=1",
                path,
            ],
            capture_output=True, text=True, timeout=5,
        )
        return float(out.stdout.strip())
    except Exception:
        return 0.0


# --- Loudness normalization ---
def init_loudness_table():
    conn = get_connection()
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS loudness_cache (
            path TEXT PRIMARY KEY,
            mtime REAL NOT NULL,
            integrated_lufs REAL NOT NULL
        )
        """
    )
    conn.commit()
    conn.close()


def _cached_loudness(path, mtime):
    conn = get_connection()
    c = conn.cursor()
    c.execute(
        "SELECT integrated_lufs FROM loudness_cache WHERE path = ? AND mtime = ?",
        (path, mtime),
    )
    row = c.fetchone()
    conn.close()
    return row[0] if row else None


def _store_loudness(path, mtime, lufs):
    conn = get_connection()
    conn.execute(
        "INSERT OR REPLACE INTO loudness_cache (path, mtime, integrated_lufs) VALUES (?, ?, ?)",
        (path, mtime, lufs),
    )
    conn.commit()
    conn.close()


def measure_loudness(path):
    """Single-pass ffmpeg loudnorm analysis. Returns integrated LUFS, or None on failure."""
    if not shutil.which("ffmpeg"):
        return None
    try:
        result = subprocess.run(
            [
                "ffmpeg", "-hide_banner", "-nostats", "-i", path,
                "-vn", "-af", "loudnorm=I=-16:TP=-1.5:LRA=11:print_format=json",
                "-f", "null", "-",
            ],
            capture_output=True, text=True, timeout=180,
        )
        stderr = result.stderr
        start = stderr.rfind("{")
        end = stderr.rfind("}")
        if start == -1 or end == -1 or end < start:
            return None
        data = json.loads(stderr[start:end + 1])
        return float(data["input_i"])
    except Exception as e:
        print(f"⚠️ Loudness analysis failed for {Path(path).name}: {e}")
        return None


def get_loudness_gain_db(path):
    """dB gain to bring `path` to LOUDNESS_TARGET_LUFS. Measures + caches on first use."""
    try:
        mtime = Path(path).stat().st_mtime
    except OSError:
        return 0.0

    lufs = _cached_loudness(path, mtime)
    if lufs is None:
        print(f"🔍 Analyzing loudness (first play): {Path(path).name}")
        lufs = measure_loudness(path)
        if lufs is None:
            return 0.0
        _store_loudness(path, mtime, lufs)

    gain = LOUDNESS_TARGET_LUFS - lufs
    return max(-LOUDNESS_MAX_CUT_DB, min(LOUDNESS_MAX_BOOST_DB, gain))


def prewarm_loudness_cache():
    """Background pass that measures every not-yet-cached track in the current
    playlist (starting from the current song), so later plays are instant."""
    with _lock:
        order = list(range(index, len(playlist))) + list(range(0, index))
        snapshot = list(playlist)
    for i in order:
        if i >= len(snapshot):
            continue
        path = snapshot[i]
        try:
            mtime = Path(path).stat().st_mtime
        except OSError:
            continue
        if _cached_loudness(path, mtime) is not None:
            continue
        lufs = measure_loudness(path)
        if lufs is not None:
            _store_loudness(path, mtime, lufs)
        time.sleep(0.2)  # be polite to CPU/disk while music is actively playing


# --- Player controls ---
def play_song(start_offset=0.0):
    global proc, paused, mpris_player
    global _play_started_at, _position_at_start, _pause_started_at, _current_length

    with _lock:
        if not playlist:
            print("⚠️ Playlist is empty.")
            return
        path = playlist[index]
        this_index = index

    # ffprobe (length) and loudnorm analysis (gain) can take a while on a
    # track's first play. Do them without holding _lock so next/prev/pause
    # etc. never block behind an analysis run.
    length = get_track_length(path)
    gain_db = get_loudness_gain_db(path)

    with _lock:
        # If the selection changed while we were analyzing (e.g. the user
        # hit Next mid-analysis), bail out rather than playing a stale track.
        if not playlist or index != this_index or playlist[index] != path:
            return

        _stop_song_locked()

        print(f"\n🎧 Now playing [{index + 1}/{len(playlist)}]: {path}")
        _current_length = length

        vol_pct = str(int(max(0.0, min(1.0, _current_volume)) * 100))
        cmd = ["ffplay", "-nodisp", "-vn", "-autoexit", "-loglevel", "quiet", "-volume", vol_pct]
        if abs(gain_db) > 0.05:
            cmd += ["-af", f"volume={gain_db:.2f}dB"]
        if start_offset > 0:
            cmd += ["-ss", str(start_offset)]
        cmd.append(path)

        # start_new_session gives ffplay its own process group so we can
        # reliably kill it (and any children it spawns) as a unit.
        proc = subprocess.Popen(cmd, start_new_session=True)
        paused = False
        _position_at_start = start_offset
        _play_started_at = time.time()
        _pause_started_at = None

        if mpris_player:
            mpris_player.update_status("Playing")
            mpris_player.update_metadata(path)


def _stop_song_locked():
    """Terminate the current process. Caller must already hold _lock."""
    global proc
    old = proc
    proc = None  # detach immediately so nothing can mistake this process for "current"
    if old is None or old.poll() is not None:
        return

    try:
        pgid = os.getpgid(old.pid)
    except ProcessLookupError:
        return

    # A stopped (paused, SIGSTOP'd) process won't act on SIGTERM until it's
    # resumed, so make sure it's running before we ask it to terminate.
    try:
        os.killpg(pgid, 18)  # SIGCONT
    except ProcessLookupError:
        return

    try:
        os.killpg(pgid, 15)  # SIGTERM
    except ProcessLookupError:
        pass

    for _ in range(10):  # poll for up to ~0.5s
        if old.poll() is not None:
            break
        time.sleep(0.05)
    else:
        try:
            os.killpg(pgid, 9)  # SIGKILL, unconditional
        except ProcessLookupError:
            pass

    try:
        old.wait(timeout=2)
    except subprocess.TimeoutExpired:
        pass


def stop_song():
    global mpris_player
    with _lock:
        _stop_song_locked()
        if mpris_player:
            mpris_player.update_status("Stopped")


def pause_song():
    global paused, mpris_player, _pause_started_at

    with _lock:
        if proc is None or proc.poll() is not None:
            return

        if not paused:
            proc.send_signal(19)  # SIGSTOP
            paused = True
            _pause_started_at = time.time()
            print("⏸️ Paused")

            if mpris_player:
                mpris_player.update_status("Paused")


def resume_song():
    global paused, mpris_player, _play_started_at, _pause_started_at

    with _lock:
        if proc is None or proc.poll() is not None:
            return

        if paused:
            proc.send_signal(18)  # SIGCONT
            if _pause_started_at is not None:
                paused_duration = time.time() - _pause_started_at
                _play_started_at += paused_duration
            paused = False
            _pause_started_at = None
            print("▶️ Resumed")

            if mpris_player:
                mpris_player.update_status("Playing")


def get_current_position():
    """Approximate elapsed seconds into the current track."""
    if not proc or proc.poll() is not None:
        return _position_at_start
    if paused and _pause_started_at is not None:
        elapsed = _pause_started_at - _play_started_at
    else:
        elapsed = time.time() - _play_started_at
    return _position_at_start + max(0.0, elapsed)


def seek_relative(offset_seconds):
    """Seek forward/backward by offset_seconds (ffplay has no IPC, so we restart at new offset)."""
    with _lock:
        if not playlist:
            return
        new_pos = get_current_position() + offset_seconds
        new_pos = max(0.0, new_pos)
        if _current_length > 0:
            new_pos = min(new_pos, max(0.0, _current_length - 0.5))
        play_song(start_offset=new_pos)


def set_position_absolute(position_seconds):
    with _lock:
        if not playlist:
            return
        position_seconds = max(0.0, position_seconds)
        if _current_length > 0:
            position_seconds = min(position_seconds, max(0.0, _current_length - 0.5))
        play_song(start_offset=position_seconds)


def next_song():
    global index
    with _lock:
        if not playlist:
            return
        index = (index + 1) % len(playlist)
        play_song()


def prev_song():
    global index
    with _lock:
        if not playlist:
            return
        index = (index - 1) % len(playlist)
        play_song()


def advance_track():
    """Called when a track finishes naturally; respects loop/shuffle state."""
    global index
    with _lock:
        if not playlist:
            return
        if _loop_status == "Track":
            play_song()
            return
        if _shuffle and len(playlist) > 1:
            index = random.randrange(len(playlist))
            play_song()
            return
        if index + 1 >= len(playlist):
            if _loop_status == "Playlist":
                index = 0
                play_song()
            else:
                print("🏁 Playlist finished.")
                _stop_song_locked()
                if mpris_player:
                    mpris_player.update_status("Stopped")
            return
        index += 1
        play_song()


def open_uri(uri):
    """MPRIS OpenUri: add a file (path or file:// URI) to the playlist and play it."""
    global playlist, playlist_ids, index
    with _lock:
        path = uri
        if uri.startswith("file://"):
            path = unquote(urlparse(uri).path)
        if not Path(path).exists():
            print(f"⚠️ File not found: {path}")
            return
        playlist.append(path)
        playlist_ids.append(None)
        index = len(playlist) - 1
        play_song()


# --- Helper to emit standard D-Bus PropertiesChanged signals ---
def emit_properties_changed(interface_name, changed_props):
    if not bus:
        return
    try:
        variant = GLib.Variant("(sa{sv}as)", (interface_name, changed_props, []))
        bus.con.emit_signal(
            None,
            "/org/mpris/MediaPlayer2",
            "org.freedesktop.DBus.Properties",
            "PropertiesChanged",
            variant,
        )
    except Exception as e:
        print(f"⚠️ Could not emit PropertiesChanged: {e}")


# --- MPRIS interface ---
class MediaPlayer2:
    """
    <node>
        <interface name='org.mpris.MediaPlayer2'>
            <method name='Raise'/>
            <method name='Quit'/>
            <property name='CanQuit' type='b' access='read'/>
            <property name='CanRaise' type='b' access='read'/>
            <property name='HasTrackList' type='b' access='read'/>
            <property name='Identity' type='s' access='read'/>
            <property name='SupportedUriSchemes' type='as' access='read'/>
            <property name='SupportedMimeTypes' type='as' access='read'/>
        </interface>
        <interface name='org.mpris.MediaPlayer2.Player'>
            <method name='Play'/>
            <method name='Pause'/>
            <method name='PlayPause'/>
            <method name='Stop'/>
            <method name='Next'/>
            <method name='Previous'/>
            <method name='Seek'>
                <arg direction='in' type='x' name='Offset'/>
            </method>
            <method name='SetPosition'>
                <arg direction='in' type='o' name='TrackId'/>
                <arg direction='in' type='x' name='Position'/>
            </method>
            <method name='OpenUri'>
                <arg direction='in' type='s' name='Uri'/>
            </method>
            <property name='PlaybackStatus' type='s' access='read'/>
            <property name='LoopStatus' type='s' access='readwrite'/>
            <property name='Rate' type='d' access='read'/>
            <property name='Shuffle' type='b' access='readwrite'/>
            <property name='Metadata' type='a{sv}' access='read'/>
            <property name='Volume' type='d' access='readwrite'/>
            <property name='Position' type='x' access='read'/>
            <property name='MinimumRate' type='d' access='read'/>
            <property name='MaximumRate' type='d' access='read'/>
            <property name='CanGoNext' type='b' access='read'/>
            <property name='CanGoPrevious' type='b' access='read'/>
            <property name='CanPlay' type='b' access='read'/>
            <property name='CanPause' type='b' access='read'/>
            <property name='CanSeek' type='b' access='read'/>
            <property name='CanControl' type='b' access='read'/>
        </interface>
    </node>
    """

    # --- org.mpris.MediaPlayer2 ---
    CanQuit = False
    CanRaise = False
    HasTrackList = False
    Identity = "FFPlay Shuffle Player"
    SupportedUriSchemes = ["file"]
    SupportedMimeTypes = [
        "audio/mpeg", "audio/x-m4a", "audio/flac", "audio/ogg",
        "video/mp4", "video/x-matroska",
    ]

    def Raise(self):
        pass  # no window to raise

    def Quit(self):
        stop_song()
        sys.exit(0)

    # --- org.mpris.MediaPlayer2.Player ---
    PlaybackStatus = "Stopped"
    Rate = 1.0
    MinimumRate = 1.0
    MaximumRate = 1.0
    CanGoNext = True
    CanGoPrevious = True
    CanPlay = True
    CanPause = True
    CanSeek = True
    CanControl = True

    Metadata = {
        "xesam:title": GLib.Variant("s", "Unknown"),
        "xesam:artist": GLib.Variant("as", ["Unknown"]),
        "xesam:album": GLib.Variant("s", "Unknown"),
    }

    @property
    def LoopStatus(self):
        return _loop_status

    @LoopStatus.setter
    def LoopStatus(self, value):
        global _loop_status
        if value in ("None", "Track", "Playlist"):
            _loop_status = value
            emit_properties_changed(
                "org.mpris.MediaPlayer2.Player", {"LoopStatus": GLib.Variant("s", value)}
            )

    @property
    def Shuffle(self):
        return _shuffle

    @Shuffle.setter
    def Shuffle(self, value):
        global _shuffle
        _shuffle = bool(value)
        emit_properties_changed(
            "org.mpris.MediaPlayer2.Player", {"Shuffle": GLib.Variant("b", _shuffle)}
        )

    @property
    def Volume(self):
        return _current_volume

    @Volume.setter
    def Volume(self, value):
        global _current_volume
        _current_volume = max(0.0, min(1.0, float(value)))
        # ffplay has no runtime volume IPC, so re-launch at the same position with new volume
        if proc and proc.poll() is None:
            pos = get_current_position()
            stop_song()
            play_song(start_offset=pos)
        emit_properties_changed(
            "org.mpris.MediaPlayer2.Player", {"Volume": GLib.Variant("d", _current_volume)}
        )

    @property
    def Position(self):
        return int(get_current_position() * 1_000_000)

    def update_status(self, status):
        self.PlaybackStatus = status
        emit_properties_changed(
            "org.mpris.MediaPlayer2.Player", {"PlaybackStatus": GLib.Variant("s", status)}
        )

    def update_metadata(self, path):
        title = Path(path).stem
        track_id = None
        if playlist_ids and index < len(playlist_ids):
            track_id = playlist_ids[index]
        if track_id is None:
            track_id = 0
        trackid_path = f"/org/mpris/MediaPlayer2/Track/{track_id}"
        length_us = int(_current_length * 1_000_000)

        self.Metadata = {
            "mpris:trackid": GLib.Variant("o", trackid_path),
            "mpris:length": GLib.Variant("x", length_us),
            "xesam:title": GLib.Variant("s", title),
            "xesam:artist": GLib.Variant("as", ["Unknown"]),
            "xesam:album": GLib.Variant("s", "FFPlay Shuffle Player"),
        }
        emit_properties_changed(
            "org.mpris.MediaPlayer2.Player", {"Metadata": GLib.Variant("a{sv}", self.Metadata)}
        )

    def Play(self):
        if paused:
            resume_song()
        elif proc is None or proc.poll() is not None:
            play_song()

    def Pause(self):
        pause_song()

    def PlayPause(self):
        if paused:
            resume_song()
        else:
            pause_song()

    def Stop(self):
        stop_song()

    def Next(self):
        next_song()

    def Previous(self):
        prev_song()

    def Seek(self, offset):
        seek_relative(offset / 1_000_000.0)

    def SetPosition(self, track_id, position):
        set_position_absolute(position / 1_000_000.0)

    def OpenUri(self, uri):
        open_uri(uri)


# --- D-Bus registration ---
bus = SessionBus()
bus_name = "org.mpris.MediaPlayer2.ffplayplayer"
try:
    mpris_player = MediaPlayer2()
    bus.publish(bus_name, ("/org/mpris/MediaPlayer2", mpris_player))
    print(f"🎶 Registered MPRIS service as {bus_name}")
except Exception as e:
    print(f"⚠️ Could not register MPRIS service: {e}")


# --- Monitor FFplay and auto-next ---
def monitor_player():
    while True:
        with _lock:
            watched_proc = proc
            if watched_proc is not None and watched_proc.poll() is not None:
                # Re-check identity: another thread may have already replaced
                # `proc` (e.g. a manual Next) between the poll above and here.
                if proc is watched_proc:
                    advance_track()
        GLib.idle_add(lambda: None)
        GLib.usleep(500000)  # 0.5s


threading.Thread(target=monitor_player, daemon=True).start()


# --- Interactive CLI in background ---
def interactive_loop():
    global index
    while True:
        cmd = input(
            "Command (add <playlist>, remove <playlist>, next, prev, pause, play, quit): "
        ).strip()
        current_id = playlist_ids[index] if playlist_ids else None
        if cmd.startswith("add ") and current_id:
            add_current_to_playlist(current_id, cmd.replace("add ", "").strip())
        elif cmd.startswith("remove ") and current_id:
            remove_current_from_playlist(current_id, cmd.replace("remove ", "").strip())
        elif cmd == "next":
            next_song()
        elif cmd == "prev":
            prev_song()
        elif cmd == "pause":
            pause_song()
        elif cmd == "play":
            resume_song()
        elif cmd == "quit":
            stop_song()
            print("👋 Exiting player.")
            sys.exit(0)
        else:
            print("⚠️ Unknown command.")


# --- Main ---
def main():
    global playlist, playlist_ids, index

    init_loudness_table()

    if len(sys.argv) > 1 and sys.argv[1] != "--all":
        playlist_name = sys.argv[1]
        print(f"📂 Loading playlist: {playlist_name}")
        playlist, playlist_ids = get_playlist_tracks(playlist_name)
        if not playlist:
            sys.exit(1)
    else:
        conn = get_connection()
        c = conn.cursor()
        c.execute("SELECT id, path FROM tracks")
        rows = c.fetchall()
        conn.close()
        playlist_ids = [r[0] for r in rows]
        playlist = [r[1] for r in rows]
        print(f"📂 Loaded {len(playlist)} tracks from library")

    random.shuffle(playlist)
    index = 0
    play_song()

    # Quietly pre-analyze the rest of the library's loudness in the background
    # so future plays don't pay the first-time analysis cost.
    threading.Thread(target=prewarm_loudness_cache, daemon=True).start()

    # Start CLI in a background thread
    threading.Thread(target=interactive_loop, daemon=True).start()

    # Start GLib main loop in main thread for MPRIS / media keys
    loop = GLib.MainLoop()
    try:
        loop.run()
    except KeyboardInterrupt:
        stop_song()
        print("\n👋 Exiting gracefully.")


if __name__ == "__main__":
    main()
